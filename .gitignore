# Rust
target/
**/target/
# Cargo.lock is committed (binary crates) -- do not ignore it

# Python
__pycache__/
*.pyc
.venv/
venv/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
tfplan*
*.tfplan
# .terraform.lock.hcl is committed (pins provider versions reproducibly, like Cargo.lock) -- do not ignore it

# Data (raw/simulated datasets are not committed)
data/raw/*
!data/raw/.gitkeep
data/simulated/*
!data/simulated/.gitkeep
dashboards/extracts/

# MLflow local tracking store
mlruns/
mlflow.db

# Ingestion runtime output
dead_letter.jsonl
ingested_output.jsonl

# Secrets
.env
.env.*
*.key
*credentials*

# OS / IDE
.DS_Store
.vscode/
.idea/
