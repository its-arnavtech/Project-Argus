<?xml version='1.0' encoding='utf-8' ?>
<!--
  Project Argus - fraud ops workbook (Chunk 9).

  Hand-authored XML: structure, data source binding, and the three PDD
  section 3 calculated fields are implemented and reviewed, but this
  environment has no Tableau Desktop, so the visual layout has NOT been
  rendered/verified. Open in Tableau Desktop to confirm; the data source
  path is relative (extracts/argus_tableau_extract.csv - regenerate via
  dashboards/export_tableau_extract.py).

  SPEC CORRECTION (logged in context.md): the PDD's Syndicate Cascade Index
  formula uses row-level [proxy_flag] inside an otherwise-aggregate
  expression, which Tableau rejects ("cannot mix aggregate and
  non-aggregate arguments"). Implemented with MAX([proxy_flag]) - the
  minimal change that preserves the intent (any proxy exposure in the
  aggregation scope applies the 1.5x multiplier).
-->
<workbook source-platform='win' version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <preference name='ui.encoding.shelf.height' value='24' />
  </preferences>
  <datasources>
    <datasource caption='Argus Fraud Extract' inline='true' name='federated.argus' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='argus_tableau_extract' name='textscan.argus'>
            <connection class='textscan' directory='extracts' filename='argus_tableau_extract.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.argus' name='argus_tableau_extract.csv' table='[argus_tableau_extract#csv]' type='table'>
          <columns character-set='UTF-8' header='yes' locale='en_US' separator=','>
            <column datatype='string' name='tx_id' ordinal='0' />
            <column datatype='real' name='amount' ordinal='1' />
            <column datatype='integer' name='timestamp' ordinal='2' />
            <column datatype='string' name='acct_id' ordinal='3' />
            <column datatype='integer' name='velocity_score_1m' ordinal='4' />
            <column datatype='string' name='device_hash' ordinal='5' />
            <column datatype='boolean' name='proxy_flag' ordinal='6' />
            <column datatype='real' name='gnn_risk_score' ordinal='7' />
            <column datatype='boolean' name='sar_grounded' ordinal='8' />
            <column datatype='integer' name='hop_distance' ordinal='9' />
            <column datatype='boolean' name='is_ring_member' ordinal='10' />
            <column datatype='string' name='ring_type' ordinal='11' />
          </columns>
        </relation>
      </connection>
      <column datatype='string' name='[tx_id]' role='dimension' type='nominal' />
      <column datatype='real' name='[amount]' role='measure' type='quantitative' />
      <column datatype='integer' name='[timestamp]' role='measure' type='quantitative' />
      <column datatype='string' name='[acct_id]' role='dimension' type='nominal' />
      <column datatype='integer' name='[velocity_score_1m]' role='measure' type='quantitative' />
      <column datatype='string' name='[device_hash]' role='dimension' type='nominal' />
      <column datatype='boolean' name='[proxy_flag]' role='dimension' type='nominal' />
      <column datatype='real' name='[gnn_risk_score]' role='measure' type='quantitative' />
      <column datatype='boolean' name='[sar_grounded]' role='dimension' type='nominal' />
      <column datatype='integer' name='[hop_distance]' role='measure' type='quantitative' />
      <column datatype='boolean' name='[is_ring_member]' role='dimension' type='nominal' />
      <column datatype='string' name='[ring_type]' role='dimension' type='nominal' />

      <!-- PDD section 3, calculated field 1 (with the MAX() correction) -->
      <column caption='Syndicate Cascade Index' datatype='real' name='[Syndicate Cascade Index]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([tx_id]) * SUM([amount]) * AVG([velocity_score_1m]) * IF MAX([proxy_flag]) THEN 1.5 ELSE 1.0 END' />
      </column>

      <!-- PDD section 3, calculated field 2 (verbatim) -->
      <column caption='Multi-Hop Risk Dispersion Factor' datatype='real' name='[Multi-Hop Risk Dispersion Factor]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gnn_risk_score]) / (1.0 + LN(AVG([hop_distance])))' />
      </column>

      <!-- PDD section 3, calculated field 3 (verbatim LOD expression) -->
      <column caption='Device Sharing Density Ratio' datatype='integer' name='[Device Sharing Density Ratio]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [device_hash]: COUNTD([acct_id])}' />
      </column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Syndicate Cascade by Account'>
      <table>
        <view>
          <datasources>
            <datasource caption='Argus Fraud Extract' name='federated.argus' />
          </datasources>
          <datasource-dependencies datasource='federated.argus'>
            <column datatype='string' name='[acct_id]' role='dimension' type='nominal' />
            <column caption='Syndicate Cascade Index' datatype='real' name='[Syndicate Cascade Index]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([tx_id]) * SUM([amount]) * AVG([velocity_score_1m]) * IF MAX([proxy_flag]) THEN 1.5 ELSE 1.0 END' />
            </column>
            <column datatype='boolean' name='[is_ring_member]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.argus].[is_ring_member]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.argus].[Syndicate Cascade Index]</rows>
        <cols>[federated.argus].[acct_id]</cols>
      </table>
    </worksheet>
    <worksheet name='Multi-Hop Risk Dispersion'>
      <table>
        <view>
          <datasources>
            <datasource caption='Argus Fraud Extract' name='federated.argus' />
          </datasources>
          <datasource-dependencies datasource='federated.argus'>
            <column datatype='string' name='[ring_type]' role='dimension' type='nominal' />
            <column caption='Multi-Hop Risk Dispersion Factor' datatype='real' name='[Multi-Hop Risk Dispersion Factor]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([gnn_risk_score]) / (1.0 + LN(AVG([hop_distance])))' />
            </column>
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
          </pane>
        </panes>
        <rows>[federated.argus].[Multi-Hop Risk Dispersion Factor]</rows>
        <cols>[federated.argus].[ring_type]</cols>
      </table>
    </worksheet>
    <worksheet name='Device Sharing Density'>
      <table>
        <view>
          <datasources>
            <datasource caption='Argus Fraud Extract' name='federated.argus' />
          </datasources>
          <datasource-dependencies datasource='federated.argus'>
            <column datatype='string' name='[device_hash]' role='dimension' type='nominal' />
            <column caption='Device Sharing Density Ratio' datatype='integer' name='[Device Sharing Density Ratio]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [device_hash]: COUNTD([acct_id])}' />
            </column>
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
          </pane>
        </panes>
        <rows>[federated.argus].[Device Sharing Density Ratio]</rows>
        <cols>[federated.argus].[device_hash]</cols>
      </table>
    </worksheet>
  </worksheets>
  <windows>
    <window class='worksheet' name='Syndicate Cascade by Account' />
    <window class='worksheet' name='Multi-Hop Risk Dispersion' />
    <window class='worksheet' name='Device Sharing Density' />
  </windows>
</workbook>
